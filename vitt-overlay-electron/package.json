{
  "name": "vitt-overlay-ui",
  "version": "1.0.0",
  "description": "Run on macOS: ```bash npm install npm run start ``` Hotkeys: - Toggle click-through: **⌥ + `** - Hide/Show: **⌥ ⇧ H** - Reload: **⌥ ⇧ R**",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "dev": "electron .",
    "build:renderer": "cd ../vitt-overlay-react-client && npm run build",
    "dist": "npm run build:renderer && electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@fortawesome/react-fontawesome": "^3.1.0",
    "@recallai/desktop-sdk": "^2.0.4",
    "@reduxjs/toolkit": "^2.9.0",
    "@ricky0123/vad-react": "^0.0.30",
    "axios": "^1.13.2",
    "dotenv": "^17.2.3",
    "html-react-parser": "^5.2.16",
    "imagemagick-cli": "^0.5.0",
    "lucide-react": "^0.546.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-entypo": "^1.3.0",
    "react-loading-icons": "^1.1.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.10.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "baseline-browser-mapping": "^2.9.13",
    "electron": "^38.1.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2"
  },
  "build": {
    "appId": "com.VittAi.overlay",
    "productName": "Overlay-Vitt",
    "files": ["dist", "main.js", "preload.js", "build", ".env"],
    "extraResources": [
      { "from": ".env", "to": ".env" },
      { "from": "../vitt-overlay-react-client/dist", "to": "client-dist" }
    ],
    "win": {
      "target": "portable",
      "icon": "build/vitt-logo.png"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns"
    },
    "directories": {
      "output": "dist-mac"
    }
  }
}
